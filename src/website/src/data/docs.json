  {
    "id": "ai",
    "title": "AI",
    "description": "AI-powered features including caption generation and text paraphrasing.",
    "endpoints": [
      {
        "id": "post-caption",
        "name": "Generate Caption",
        "method": "POST",
        "path": "/v1/ai/caption",
        "description": "Generate a social media caption from a description.",
        "parameters": [
          { "name": "text", "type": "string", "required": true, "description": "Description or context" },
          { "name": "tone", "type": "string", "required": false, "description": "funny, inspirational, professional, casual" }
        ],
        "exampleRequest": {
          "tabs": [
            {
              "id": "curl",
              "label": "cURL",
              "language": "curl",
              "code": "curl -X POST \"https://api.masukkan-nama.com/v1/ai/caption\" \\\n-H \"Content-Type: application/json\" \\\n-d '{\"text\": \"sunset at the beach\", \"tone\": \"funny\"}'"
            }
          ]
        },
        "exampleResponse": {
          "success": true,
          "data": {
            "input": "sunset at the beach",
            "tone": "funny",
            "caption": "When sunset hits different 😎 #vibes #mood #lit",
            "hashtags": ["#vibes", "#mood", "#lit", "#no-cap", "#fr"]
          }
        }
      },
      {
        "id": "post-paraphrase",
        "name": "Paraphrase Text",
        "method": "POST",
        "path": "/v1/ai/paraphrase",
        "description": "Paraphrase text with different word choices.",
        "parameters": [
          { "name": "text", "type": "string", "required": true, "description": "Text to paraphrase" },
          { "name": "style", "type": "string", "required": false, "description": "Paraphrase style" }
        ],
        "exampleRequest": {
          "tabs": [
            {
              "id": "curl",
              "label": "cURL",
              "language": "curl",
              "code": "curl -X POST \"https://api.masukkan-nama.com/v1/ai/paraphrase\" \\\n-H \"Content-Type: application/json\" \\\n-d '{\"text\": \"I love this product\", \"style\": \"simple\"}'"
            }
          ]
        },
        "exampleResponse": {
          "success": true,
          "data": {
            "original": "I love this product",
            "paraphrased": "I appreciate this product",
            "style": "simple",
            "replacements": 1
          }
        }
      },
      {
        "id": "post-sentiment",
        "name": "Sentiment Analysis",
        "method": "POST",
        "path": "/v1/ai/sentiment",
        "description": "Analyze the sentiment of text (positive, negative, or neutral).",
        "parameters": [
          { "name": "text", "type": "string", "required": true, "description": "Text to analyze" }
        ],
        "exampleRequest": {
          "tabs": [
            {
              "id": "curl",
              "label": "cURL",
              "language": "curl",
              "code": "curl -X POST \"https://api.masukkan-nama.com/v1/ai/sentiment\" \\\n-H \"Content-Type: application/json\" \\\n-d '{\"text\": \"This is an amazing product!\"}'"
            }
          ]
        },
        "exampleResponse": {
          "success": true,
          "data": {
            "text": "This is an amazing product!",
            "sentiment": "positive",
            "score": 2,
            "positiveCount": 2,
            "negativeCount": 0
          }
        }
      }
    ]
  },
  {
    "id": "downloader",
    "title": "Downloader",
    "description": "Multi-platform media downloader API for videos, audio, and images.",
    "endpoints": [
      {
        "id": "get-youtube",
        "name": "Download YouTube Video",
        "method": "GET",
        "path": "/v1/downloader/youtube",
        "description": "Download YouTube video with merged audio+video format.",
        "parameters": [
          { "name": "url", "type": "string", "required": true, "description": "YouTube video URL" }
        ],
        "exampleRequest": {
          "tabs": [
            {
              "id": "curl",
              "label": "cURL",
              "language": "curl",
              "code": "curl -X GET \"https://api.masukkan-nama.com/v1/downloader/youtube?url=https%3A%2F%2Fyoutube.com%2Fwatch%3Fv%3DOVGOkz3Slsc\""
            }
          ]
        },
        "exampleResponse": {
          "success": true,
          "message": "Video fetched successfully",
          "data": {
            "title": "Video Title",
            "uploader": "Channel Name",
            "mediaItems": [
              { "type": "video", "url": "https://download.url/video.mp4", "extension": "mp4", "width": 1920, "height": 1080 }
            ]
          }
        }
      },
      {
        "id": "post-tiktok",
        "name": "Download TikTok Video",
        "method": "POST",
        "path": "/v1/downloader/tiktok",
        "description": "Download TikTok video without watermark.",
        "parameters": [
          { "name": "url", "type": "string", "required": true, "description": "TikTok video URL" }
        ],
        "exampleRequest": {
          "tabs": [
            {
              "id": "curl",
              "label": "cURL",
              "language": "curl",
              "code": "curl -X POST \"https://api.masukkan-nama.com/v1/downloader/tiktok\" \\\n-H \"Content-Type: application/json\" \\\n-d '{\"url\": \"https://www.tiktok.com/@user/video/123\"}'"
            }
          ]
        },
        "exampleResponse": {
          "success": true,
          "data": {
            "title": "TikTok Description",
            "uploader": "username",
            "mediaItems": [
              { "type": "video", "url": "https://download.url/video.mp4", "extension": "mp4" }
            ]
          }
        },
        "notes": ["TikTok may block IP addresses with rate limiting"]
      },
